# Скопируй этот файл в .env.local и впиши значения из
# Supabase → Project Settings → API.
# Переменные с префиксом VITE_ попадают в браузерный бандл —
# здесь только публичный (anon / publishable) ключ, секретный не нужен.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
